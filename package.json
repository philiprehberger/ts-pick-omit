{
  "name": "@philiprehberger/pick-omit",
  "version": "0.2.0",
  "description": "Type-safe shallow and deep pick/omit utilities for JavaScript objects",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pick",
    "omit",
    "object",
    "deep",
    "filter",
    "lodash",
    "flatten",
    "unflatten",
    "typescript"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-pick-omit.git"
  },
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-pick-omit/issues"
  },
  "homepage": "https://github.com/philiprehberger/ts-pick-omit#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2",
    "unrun": "^0.3.1"
  }
}
